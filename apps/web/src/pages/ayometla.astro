---
// 🔥 ÚNICO CAMBIO: La nueva ruta hacia la carpeta core
import { db } from "../../../../core/services/firebase";
import { collection, getDocs } from "firebase/firestore";

const negociosRef = collection(db, "municipios/ayometla/negocios");
const querySnapshot = await getDocs(negociosRef);

// Solución: Tipado explícito para que TypeScript compile sin errores
const negocios = querySnapshot.docs.map(doc => {
  const data = doc.data();
  return {
    id: doc.id,
    nombre: data.nombre as string,
    categoria: data.categoria as string
  };
});
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Ayometla - Smart Tlaxcala</title>
  </head>
  <body>
    <h1>Ayometla</h1>
    <p>Directorio de negocios locales:</p>

    {negocios.length > 0 ? (
      <ul>
        {negocios.map((negocio) => (
          <li>
            <strong>{negocio.nombre}</strong> - <em>{negocio.categoria}</em>
          </li>
        ))}
      </ul>
    ) : (
      <p>Aún no hay negocios registrados en este municipio.</p>
    )}

    <br>
    <a href="/">← Volver a inicio</a>
  </body>
</html>