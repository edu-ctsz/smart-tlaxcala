---
import Layout from '../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { municipio: 'ayometla' }, props: { name: 'Ayometla' } },
    { params: { municipio: 'san-lorenzo' }, props: { name: 'San Lorenzo' } },
    { params: { municipio: 'santo-toribio' }, props: { name: 'Santo Toribio' } },
  ];
}

const { municipio } = Astro.params;
const { name } = Astro.props;

// Datos de conexión emocional por municipio y coordenadas reales
const mData = {
  'ayometla': {
    lat: 19.2078,
    lng: -98.2045,
    bg: 'https://upload.wikimedia.org/wikipedia/commons/9/9b/Templo_de_Santa_Catarina_Ayometla%2C_Tlaxcala.jpg',
    facts: [
      "Su nombre en náhuatl 'Ayometitla' significa 'En el acueducto del maguey'.",
      "Fue constituido formalmente como municipio libre e independiente en el año 1995.",
      "La Iglesia de Santa Catarina registra sus primeros bautizos desde el antiguo año 1523.",
      "Antiguamente, en este lugar se veneraba a Xilonenteotl, la diosa prehispánica del maíz.",
      "Sus artesanos son reconocidos en todo el estado por su excelente trabajo en hojalatería."
    ]
  },
  'san-lorenzo': {
    lat: 19.2255,
    lng: -98.2443,
    bg: 'https://upload.wikimedia.org/wikipedia/commons/0/08/Iglesia_de_San_Lorenzo_Axocomantila%2C_Tlaxcala.jpg',
    facts: [
      "Es oficialmente el municipio con menor extensión territorial de todo México.",
      "Su nombre completo 'Axocomanitla' se traduce como 'Lugar donde hay agua agria'.",
      "Fue fundado en 1465 por militares de Ocotelulco como un punto estratégico de defensa.",
      "La población original estaba en Teopantzol, pero se mudaron por inundaciones.",
      "La leyenda cuenta que la imagen de San Lorenzo fue trasladada desde Ocotlán tras una aparición."
    ]
  },
  'santo-toribio': {
    lat: 19.1822,
    lng: -98.2321,
    bg: 'https://upload.wikimedia.org/wikipedia/commons/thumb/d/de/Parroquia_de_Santo_Toribio%2C_Xicohtzinco%2C_Tlaxcala.jpg/1280px-Parroquia_de_Santo_Toribio%2C_Xicohtzinco%2C_Tlaxcala.jpg',
    facts: [
      "Su nombre 'Xicohtzinco' significa 'Detrás de los jicotes' o lugar de pequeñas avispas.",
      "La leyenda dice que una gran 'jicotera' impidió a los pobladores trasladar al santo patrono.",
      "Su hermosa parroquia barroca cuenta con cúpulas revestidas en auténtica talavera.",
      "Fue fundado originalmente por antiguas tribus teochichimecas en la época prehispánica.",
      "Las dos torres de su iglesia unidas por un gran arco son consideradas un símbolo de paz."
    ]
  }
};

const currentData = mData[municipio as keyof typeof mData] || mData['ayometla'];
// Convertir a string para pasarlo al cliente
const factsString = JSON.stringify(currentData.facts);
---

<Layout title={`Explorar ${name}`}>
  
  <!-- Hero Background Image (Conexión Visual) -->
  <div class="hero-bg" style={`background-image: url('${currentData.bg}');`}>
    <div class="hero-overlay"></div>
  </div>

  <!-- Sticky App-Bar (Transparente sobre la imagen) -->
  <div class="sticky-app-bar">
    <div class="app-bar-top">
      <a href="/" class="back-btn">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      </a>
      <h2>{name}</h2>
      <div class="header-action"></div>
    </div>
  </div>

  <div class="container main-content" id="pageData" data-municipio={municipio} data-lat={currentData.lat} data-lng={currentData.lng} data-facts={factsString}>
    
    <!-- Hero Greeting & Weather -->
    <div class="hero-greeting">
      <div class="weather-pill" id="weatherContainer" style="display: none;">
        <span id="weatherIcon">☀️</span> 
        <span id="weatherTemp">--°C</span>
      </div>
      <h1 id="greetingText">Hola,</h1>
      <p>Explora todo lo que {name} tiene para ofrecerte.</p>
    </div>

    <!-- Quick Access Grid (Super App Style) -->
    <div class="quick-access-grid">
      <a href={`/${municipio}/negocios`} class="quick-card bg-negocio">
        <span class="icon">🏪</span>
        <span class="label">Locales y Negocios</span>
      </a>
      <a href={`/${municipio}/turismo`} class="quick-card bg-turismo">
        <span class="icon">📸</span>
        <span class="label">Turismo</span>
      </a>
      <a href={`/${municipio}/transporte`} class="quick-card bg-transporte">
        <span class="icon">🚐</span>
        <span class="label">Transporte</span>
      </a>
      <a href={`/${municipio}/eventos`} class="quick-card bg-evento">
        <span class="icon">🎉</span>
        <span class="label">Eventos</span>
      </a>
      <a href={`/${municipio}/avisos`} class="quick-card bg-aviso">
        <span class="icon">📢</span>
        <span class="label">Avisos Oficiales</span>
      </a>
    </div>

    <!-- Sabías que... (Cultura y Tradición Dinámica) -->
    <div class="cultural-card fade-in" id="culturalCard">
      <div class="cultural-icon">💡</div>
      <div class="cultural-content">
        <h4>Sabías que...</h4>
        <p id="culturalFact">Cargando dato curioso...</p>
      </div>
    </div>

    <!-- Sección de Destacados (Carrusel) -->
    <div class="section-header">
      <h3>Destacados en {name}</h3>
    </div>
    
    <div class="carousel-container" id="destacadosCarousel">
      <!-- Mocks Temporales hasta que cargue Firebase -->
      <a href="#" class="carousel-card skeleton-card">
        <div class="carousel-img"></div>
        <div class="carousel-info">
          <h4>Cargando...</h4>
          <p>...</p>
        </div>
      </a>
      <a href="#" class="carousel-card skeleton-card">
        <div class="carousel-img"></div>
        <div class="carousel-info">
          <h4>Cargando...</h4>
          <p>...</p>
        </div>
      </a>
    </div>

    <!-- Footer Space -->
    <div style="height: 60px;"></div>
  </div>

  <!-- FAB Botón Mapa (Oculto temporalmente) -->
  <!--
  <button class="fab-map pulse-animation">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon><line x1="8" y1="2" x2="8" y2="18"></line><line x1="16" y1="6" x2="16" y2="22"></line></svg>
    Ver Mapa
  </button>
  -->

</Layout>

<script>
  import { db } from "../lib/firebase";
  import { collection, getDocs, query, where, limit } from "firebase/firestore";

  document.addEventListener('DOMContentLoaded', async () => {
    const pageData = document.getElementById('pageData');
    const currentMunicipio = pageData?.getAttribute('data-municipio');
    const lat = pageData?.getAttribute('data-lat');
    const lng = pageData?.getAttribute('data-lng');
    const factsStr = pageData?.getAttribute('data-facts');

    // 1. Contextual Greeting
    const greetingText = document.getElementById('greetingText');
    const hour = new Date().getHours();
    let greeting = 'Hola';
    if (hour >= 5 && hour < 12) greeting = 'Buenos días,';
    else if (hour >= 12 && hour < 19) greeting = 'Buenas tardes,';
    else greeting = 'Buenas noches,';
    if(greetingText) greetingText.innerText = greeting;

    // 2. Real-Time Weather via Open-Meteo API
    const weatherContainer = document.getElementById('weatherContainer');
    const weatherIcon = document.getElementById('weatherIcon');
    const weatherTemp = document.getElementById('weatherTemp');
    
    if (weatherContainer && weatherIcon && weatherTemp && lat && lng) {
      try {
        const req = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&current_weather=true`);
        const res = await req.json();
        
        if (res && res.current_weather) {
          const temp = Math.round(res.current_weather.temperature);
          const isDay = res.current_weather.is_day;
          
          weatherTemp.innerText = `${temp}°C`;
          weatherIcon.innerText = isDay ? '☀️' : '🌙';
          weatherContainer.style.display = 'inline-flex';
        }
      } catch(e) {
        console.log("No se pudo obtener el clima en vivo.");
      }
    }

    // 3. Random Cultural Fact Rotation
    const culturalFact = document.getElementById('culturalFact');
    if (factsStr && culturalFact) {
      try {
        const facts = JSON.parse(factsStr);
        // Show a random one on load
        const setRandomFact = () => {
          const randIndex = Math.floor(Math.random() * facts.length);
          culturalFact.innerText = facts[randIndex];
        };
        setRandomFact();
        
        // Rotar cada 8 segundos
        setInterval(() => {
          culturalFact.style.opacity = '0';
          setTimeout(() => {
            setRandomFact();
            culturalFact.style.opacity = '1';
          }, 300); // 300ms transition time
        }, 8000);
      } catch(e) {}
    }

    // 4. Destacados Fetch
    const destacadosCarousel = document.getElementById('destacadosCarousel');
    if (currentMunicipio && destacadosCarousel) {
      try {
        const q = query(collection(db, "negocios"), 
                        where("municipio", "==", currentMunicipio), 
                        where("estado", "==", "activo"),
                        limit(5));
                        
        const snap = await getDocs(q);
        
        let html = '';
        snap.forEach(doc => {
          const data = doc.data();
          const imgUrl = data.photoUrl ? `url('${data.photoUrl}')` : 'none';
          const bgColor = data.photoUrl ? 'transparent' : '#fef3c7';
          const iconHTML = data.photoUrl ? '' : '<span style="font-size:3rem; display:flex; justify-content:center; align-items:center; height:100%;">🏪</span>';

          html += `
            <a href="/${currentMunicipio}/detalle?id=${doc.id}" class="carousel-card">
              <div class="carousel-img" style="background-image: ${imgUrl}; background-color: ${bgColor};">
                ${iconHTML}
              </div>
              <div class="carousel-info">
                <h4>${data.nombre}</h4>
                <p>${data.categoria || 'Negocio Local'}</p>
              </div>
            </a>
          `;
        });
        
        if (html === '') {
          html = `
            <a href="#" class="carousel-card">
              <div class="carousel-img" style="background-color: #fef3c7;"><span style="font-size:3rem; display:flex; justify-content:center; align-items:center; height:100%;">🌮</span></div>
              <div class="carousel-info">
                <h4>Taquería El Pastor (Mock)</h4>
                <p>Comida</p>
              </div>
            </a>
            <a href="#" class="carousel-card">
              <div class="carousel-img" style="background-color: #dcfce7;"><span style="font-size:3rem; display:flex; justify-content:center; align-items:center; height:100%;">⛪</span></div>
              <div class="carousel-info">
                <h4>Parroquia Principal (Mock)</h4>
                <p>Turismo</p>
              </div>
            </a>
          `;
        }
        destacadosCarousel.innerHTML = html;
      } catch (error) {
        console.error("Error cargando destacados:", error);
      }
    }
  });
</script>

<style is:global>
  /* Hero Background Integration */
  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 350px;
    background-size: cover;
    background-position: center;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(245, 247, 250, 0.4) 0%, var(--color-bg) 100%);
  }

  .sticky-app-bar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(245, 247, 250, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255,255,255,0.2);
    padding: 16px 20px 0;
  }

  .app-bar-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .back-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    color: var(--color-text);
  }

  .app-bar-top h2 {
    font-size: 1.25rem;
    font-weight: 700;
  }

  .header-action {
    width: 40px;
  }

  .main-content {
    position: relative;
    z-index: 10;
    padding-top: 24px;
  }

  .hero-greeting {
    margin-bottom: 32px;
  }

  .weather-pill {
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.8);
    backdrop-filter: blur(8px);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 12px;
    box-shadow: var(--shadow-sm);
  }

  .hero-greeting h1 {
    font-size: 2.2rem;
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 8px;
    color: var(--color-text);
  }

  .hero-greeting p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    font-weight: 500;
    margin: 0;
  }

  /* Cultural Card */
  .cultural-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 20px;
    display: flex;
    gap: 16px;
    margin-bottom: 40px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border);
  }

  .cultural-icon {
    font-size: 2rem;
  }

  .cultural-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .cultural-content h4 {
    font-size: 1rem;
    margin-bottom: 4px;
    color: var(--color-primary);
  }

  .cultural-content p {
    font-size: 0.9rem;
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.4;
    transition: opacity 0.3s ease-in-out;
  }

  /* Quick Access Grid Bento */
  .quick-access-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }

  .quick-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    padding: 16px;
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.2s, box-shadow 0.2s;
    min-height: 110px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }

  .quick-card:active {
    transform: scale(0.96);
  }

  .quick-card:first-child {
    grid-column: span 2;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: 20px;
    padding: 24px;
    min-height: 120px;
  }

  .quick-card:first-child .icon {
    font-size: 3rem;
    margin-bottom: 0;
  }

  .quick-card:first-child .label {
    font-size: 1.3rem;
    font-weight: 800;
  }

  .quick-card .icon {
    font-size: 2rem;
    margin-bottom: auto;
  }

  .quick-card .label {
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.2;
    margin-top: 12px;
  }

  .bg-negocio { background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); }
  .bg-turismo { background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%); }
  .bg-transporte { background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%); }
  .bg-evento { background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%); }
  .bg-aviso { background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%); }

  /* Carousel Destacados */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .section-header h3 {
    font-size: 1.25rem;
    font-weight: 800;
    margin: 0;
  }

  .carousel-container {
    display: flex;
    overflow-x: auto;
    gap: 16px;
    padding-bottom: 16px;
    scroll-snap-type: x mandatory;
    -ms-overflow-style: none;
    scrollbar-width: none;
    margin: 0 -20px;
    padding: 0 20px 20px 20px;
  }

  .carousel-container::-webkit-scrollbar { display: none; }

  .carousel-card {
    min-width: 260px;
    max-width: 260px;
    scroll-snap-align: center;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s;
  }

  .carousel-card:active {
    transform: scale(0.98);
  }

  .carousel-img {
    height: 140px;
    background-size: cover;
    background-position: center;
    background-color: var(--color-border);
  }

  .carousel-info {
    padding: 16px;
  }

  .carousel-info h4 {
    margin-bottom: 4px;
    font-size: 1.1rem;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .carousel-info p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin: 0;
  }

  .skeleton-card {
    opacity: 0.6;
    pointer-events: none;
  }
</style>
